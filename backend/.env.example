NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/medpulse
CORS_ORIGIN=http://localhost:5173,https://med-pluse-frontend.vercel.app

# Inbox that receives login OTPs. The demo accounts use non-real login IDs,
# so their OTPs are delivered here. Set to an inbox you control.
OTP_DELIVERY_EMAIL=

# OTP email via nodemailer (SMTP).
# Gmail works locally (defaults below). Render blocks Gmail's SMTP ports, so in
# production point these at an SMTP provider that isn't port-blocked
# (e.g. Brevo: smtp-relay.brevo.com:587, Mailgun, or Resend SMTP).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
# Sender address (defaults to EMAIL_USER), e.g. "MedPulse <noreply@yourdomain.com>"
EMAIL_FROM=
