NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/medpulse
CORS_ORIGIN=http://localhost:5173,https://med-pluse-frontend.vercel.app

# OTP email delivery.
# Preferred in production (works on Render; SMTP ports are blocked there):
#   RESEND_API_KEY  - API key from https://resend.com
#   EMAIL_FROM      - verified sender, e.g. "MedPulse <noreply@yourdomain.com>"
#                     (defaults to Resend's onboarding sender for testing)
RESEND_API_KEY=
EMAIL_FROM=

# SMTP fallback (Gmail). Works locally; usually blocked on Render.
EMAIL_USER=
EMAIL_PASS=
