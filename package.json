{
  "name": "medpulse",
  "version": "1.0.0",
  "description": "MedPulse - MERN hospital management system",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @medpulse/backend\" \"npm run dev --workspace @medpulse/frontend\"",
    "dev:frontend": "npm run dev --workspace @medpulse/frontend",
    "dev:backend": "npm run dev --workspace @medpulse/backend",
    "build": "npm run build --workspace @medpulse/frontend",
    "start": "npm run start --workspace @medpulse/backend",
    "lint": "npm run lint --workspace @medpulse/frontend",
    "test": "npm run test --workspace @medpulse/backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
     "node": "20.x",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vaibhavon/medPulse.git"
  },
  "keywords": [
    "hospital",
    "management",
    "mern",
    "react",
    "node",
    "mongodb"
  ],
  "author": "MedPulse Team",
  "license": "ISC"
}
